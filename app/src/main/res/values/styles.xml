<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="FeedDogTheme" parent="@android:style/Theme.DeviceDefault.Light">
        <item name="android:windowBackground">@drawable/bg_app_surface</item>
        <item name="android:colorAccent">#3B82F6</item>
        <item name="android:alertDialogTheme">@style/FeedDogDialogTheme</item>
        <item name="android:popupMenuStyle">@style/FeedDogPopupMenuStyle</item>
        <item name="android:actionOverflowMenuStyle">@style/FeedDogPopupMenuStyle</item>
        <item name="android:textAppearanceLargePopupMenu">@style/FeedDogPopupMenuText</item>
        <item name="android:textAppearanceSmallPopupMenu">@style/FeedDogPopupMenuText</item>
    </style>

    <style name="FeedDogDialogTheme" parent="@android:style/Theme.DeviceDefault.Light.Dialog.Alert">
        <item name="android:windowBackground">@drawable/dialog_bg</item>
        <item name="android:textColorPrimary">#0F172A</item>
        <item name="android:textColorSecondary">#64748B</item>
    </style>

    <style name="FeedDogPopupMenuStyle" parent="@android:style/Widget.DeviceDefault.Light.PopupMenu">
        <item name="android:popupBackground">@drawable/menu_popup_bg</item>
    </style>

    <style name="FeedDogPopupMenuText" parent="@android:style/TextAppearance.DeviceDefault.Widget.PopupMenu.Large">
        <item name="android:textColor">#1E293B</item>
        <item name="android:textSize">14sp</item>
    </style>

</resources>
