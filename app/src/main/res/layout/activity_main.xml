<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/layout_multi_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/multi_actions_panel_bg"
        android:orientation="horizontal"
        android:padding="6dp"
        android:visibility="gone">

        <Button
            android:id="@+id/btn_delete_selected"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/btn_multi_delete_bg"
            android:clipToOutline="true"
            android:elevation="0dp"
            android:minHeight="44dp"
            android:outlineProvider="background"
            android:shadowColor="@android:color/transparent"
            android:stateListAnimator="@null"
            android:text="删除"
            android:textAllCaps="false"
            android:textColor="#B42318"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_select_all"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/btn_multi_action_bg"
            android:clipToOutline="true"
            android:elevation="0dp"
            android:minHeight="44dp"
            android:outlineProvider="background"
            android:shadowColor="@android:color/transparent"
            android:stateListAnimator="@null"
            android:text="全选"
            android:textAllCaps="false"
            android:textColor="#1D4ED8"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_inverse_select"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/btn_multi_action_bg"
            android:clipToOutline="true"
            android:elevation="0dp"
            android:minHeight="44dp"
            android:outlineProvider="background"
            android:shadowColor="@android:color/transparent"
            android:stateListAnimator="@null"
            android:text="反选"
            android:textAllCaps="false"
            android:textColor="#1D4ED8"
            android:textStyle="bold" />
    </LinearLayout>

    <ListView
        android:id="@+id/list_rules"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:cacheColorHint="@android:color/transparent"
        android:divider="@android:color/transparent"
        android:dividerHeight="8dp"
        android:listSelector="@android:color/transparent" />

</LinearLayout>